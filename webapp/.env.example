NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_EXTENSION_CHROME_URL=https://chrome.google.com/webstore/detail/your-extension-id
NEXT_PUBLIC_GITHUB_URL=https://github.com/eternax/chain-intel

# === Fonti esterne ===
# GoPlus Security e ScamSniffer sono gratuite e non richiedono API key.
# Le uniche key utili sono per Etherscan (metadati on-chain) e OpenAI (AI).

# Etherscan Multichain V2 (una singola key per molte chain EVM).
# https://docs.etherscan.io/etherscan-v2
ETHERSCAN_API_KEY=

# URL di un dataset OFAC SDN di indirizzi crypto (JSON array di stringhe).
# Lasciare vuoto per usare data/ofac-seed.json come fallback.
OFAC_DATA_URL=

# === AI ===
# OpenAI API key per l'analisi narrativa (https://platform.openai.com)
OPENAI_API_KEY=
# Modello (default: gpt-4o-mini). Esempi: gpt-4o-mini, gpt-4o
OPENAI_MODEL=gpt-4o-mini

# === CORS per l'estensione Chrome ===
# ID estensione separati da virgola (chrome://extensions in dev mode).
ALLOWED_EXTENSION_IDS=

# === Cache / rate limit ===
# TTL cache risposte /api/risk in secondi (default 3600 = 1h).
# GoPlus free ha ~30 req/min per IP: cache aggressiva raccomandata.
RISK_CACHE_TTL_SECONDS=3600
# Rate limit per IP in ingresso verso la nostra API (default 30).
RATE_LIMIT_PER_MINUTE=30

# === Database ===
# Percorso file SQLite (default ./data/justice.db)
SQLITE_PATH=./data/justice.db
